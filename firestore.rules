rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Legacy rehab data remains user-owned while the v2 collections are adopted.
    match /rehabData/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Programmes, exercise definitions, workouts and settings all live below
    // the authenticated user's v2 root.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
